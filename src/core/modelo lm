        """
    
    def _clean_think(self, text: str) -> str:
        """Elimina las etiquetas <think> y su contenido."""
        if not text:
            return ""
        return re.sub(r'<think>.*?</think>', '', text, flags=re.DOTALL).strip()

    def _parse_output(self, text: str) -> Any:
        """Parsea la salida con formato |key: value| a un diccionario."""
        if not text:
            return ""
        # Asegurar limpieza final
        text = self._clean_think(text)
        
        # Extraer pares clave valor entre pipes
        parts = [p.strip() for p in text.split('|') if p.strip()]
        result = {}
        for part in parts:
            if ':' in part:
                key, value = part.split(':', 1)
                result[key.strip()] = value.strip()
        
        return result if result else text

    def generate_quicksearch(self, tit_seo: str, template_data: Dict[str, Any], nuevo_tema: str, ejemplos: List[Dict[str, Any]]) -> str:
        """
        Genera la sección de búsqueda rápida (Solo descripción).
        
        Args:
            tit_seo: Título SEO que se mantiene estático.
            template_data: Datos de la plantilla.
            nuevo_tema: Nuevo tema para generar contenido.
            ejemplos: Lista de ejemplos de referencia.
            
        Returns:
            Texto generado con el formato |tit: ...| |desc: ...|
        """
        # Obtener el volumen de palabras desde los ejemplos
        vol_h1 = ejemplos[0].get('vol_h1', '') if ejemplos else '60'
        
        print("----------------")
        print(f"Volumen H1: {vol_h1}")

        # Crear ejemplos para el prompt (usando h1 y h1_desc de la data original)
        ejemplos_texto = "\n".join(
            [f"Ejemplo {i+1}: tit: {ej.get('h1', '')}, desc: {ej.get('h1_desc', '')}" for i, ej in enumerate(ejemplos[:2])]
        )

        # Crear el prompt siguiendo tu estructura solicitada
        # Nota: Mantenemos el tit: {tit_seo} fijo para que el modelo no lo invente.
        prompt = (
            f"{ejemplos_texto}\n\n"
            f"nuevo tema: {nuevo_tema}, tit: {tit_seo}\n"
            f"reglas a tener en cuenta para desc: cantidad de palabras {vol_h1} minimo a maximo.\n"
