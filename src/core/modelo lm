            f"|tit: {tit_seo}|\n "
            f"|desc: redaccion|\n"
        )

        # Llamada directa al LLM
        respuesta_raw = self.llm_client.generate(prompt, self.system_message)
        
        # Limpiamos solo los pensamientos (<think>) si el cliente lo requiere
        resultado = self._clean_think(respuesta_raw)

        return resultado
    
