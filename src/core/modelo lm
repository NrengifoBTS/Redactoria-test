    def generate_faq_respuesta(self, nuevo_tema: str, preguntas: List[str], ejemplos: List[Dict[str, Any]]) -> str:
        vol_faq = ejemplos[0].get('vol_faq', '') if ejemplos else ''
        
        respuestas = []
        for i, pregunta in enumerate(preguntas, start=1):
            prompt_qa = (
                f"Nuevo tema: {nuevo_tema}\n"
                f"reglas a tener en cuenta para desc: cantidad de palabras {vol_faq} minimo a maximo.\n"
                f"|tit: {pregunta}|\n"
                f"|desc: "
            )
            raw = self.llm_client.generate(prompt_qa, self.system_message)
            clean = self._clean_think(raw)
            
            import re
            match = re.search(r'\|desc:\s*(.*?)\|', clean, re.DOTALL)
            valor = match.group(1).strip() if match else clean.strip()
            respuestas.append(f"|faq_{i}: {valor}|")
        
        return "\n".join(respuestas)

