# =============================================================================
# Redactoria (RIA) — Plantilla de variables de entorno del backend
# =============================================================================
# Cópialo a .env y completa los valores. NUNCA commitees el .env real.

# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@db-test:5432/cleanfastapi

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:3001

# -----------------------------------------------------------------------------
# LLM local (LM Studio)
# -----------------------------------------------------------------------------
LM_STUDIO_URL=http://host.docker.internal:1234
LM_MODEL=openai/gpt-oss-20b

# -----------------------------------------------------------------------------
# OpenAI — Revisión ortográfica/SEO de blogs
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-tu-api-key-aqui
OPENAI_REVIEW_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Microsoft Teams (opcional)
# -----------------------------------------------------------------------------
ENABLE_TEAMS_NOTIFICATIONS=false
TEAMS_WEBHOOK_URL=
TEAMS_BOT_NAME=Sistema de Notificaciones

# -----------------------------------------------------------------------------
# Otros
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001
TIMEZONE=America/Bogota
